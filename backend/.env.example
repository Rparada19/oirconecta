# ===========================================
# OirConecta Backend - Variables de Entorno
# ===========================================
# Copia este archivo a .env y completa los valores

# Entorno (en el servidor: production)
NODE_ENV=development
PORT=3001

# Desarrollo: puertos del front (Vite) permitidos por CORS, separados por coma.
# `npm run dev` en la raíz del monorepo define CORS_DEV_PORTS automáticamente.
# CORS_DEV_PORTS=5173,5174,5175,5176

# Base de datos PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:password@localhost:5432/oirconecta_db"

# JWT (secreto para firmar tokens)
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_secreto_jwt_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=7d

# Orígenes del front permitidos por CORS (producción: varios separados por coma, sin espacios extra)
# Ejemplo: https://app.oirconecta.com,https://www.oirconecta.com
FRONTEND_URL=http://localhost:5174

# Correo - opción A: Resend (HTTPS, recomendado en producción).
# Render Free bloquea SMTP saliente (25/465/587), por eso usamos Resend.
# Saca la API key en https://resend.com/api-keys (requiere verificar dominio en DNS).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMTP_FROM="OírConecta <no-reply@oirconecta.com>"

# Correo - opción B (legacy): SMTP vía nodemailer. Solo si tu host no bloquea SMTP.
# SMTP_HOST=smtp.tuproveedor.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="OírConecta <no-reply@tudominio.com>"

# Admin inicial (se crea con el seed)
ADMIN_EMAIL=admin@oirconecta.com
ADMIN_PASSWORD=Admin123!

# Retail OírConecta: professionalId de la audióloga del consultorio propio.
# Se expone en GET /api/public/retail-config y lo usa /agendar para que la
# disponibilidad pública refleje la agenda real de ese profesional en el CRM.
# Si está vacío, /agendar opera en modo global (legacy: cualquier cita bloquea).
RETAIL_PROFESSIONAL_ID=prof_1

# Correo de la audióloga del consultorio retail. Si la cita creada lleva
# professionalId == RETAIL_PROFESSIONAL_ID, se envía notificación a este correo
# y al ADMIN_EMAIL además de al paciente.
RETAIL_PROFESSIONAL_EMAIL=audiologa@oirconecta.com

# ===========================================
# FASE 1 — Sistema de notificaciones
# ===========================================

# URL base pública del front (usada en links de email/WhatsApp)
PUBLIC_BASE_URL=https://oirconecta.com

# Email (Resend). Sin esta key, el canal EMAIL simula envíos (log).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM="OÍR Conecta <no-reply@oirconecta.com>"

# WhatsApp Business — Meta Cloud API.
# Sin estas variables, el canal WHATSAPP simula envíos.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_API_VERSION=v21.0
# META_WEBHOOK_VERIFY_TOKEN=   # verificación del webhook Meta (lo eliges tú)
# META_CORPORATE_PHONE_NUMBER_ID=  # opcional; separa envíos corporativos del canal general
# WA_BOT_ENABLED=true          # activa el bot conversacional automático

# Meta Conversions API (server-side pixel events)
# Genera el token en Events Manager → Configuración → API de conversiones
# META_PIXEL_ID=1056565756928195
# META_CAPI_ACCESS_TOKEN=EAA...
# Solo en staging: código de prueba (Events Manager → Probar eventos).
# Déjalo vacío en producción para que los eventos cuenten como reales.
# META_CAPI_TEST_EVENT_CODE=

# SMS — Twilio. Sin estas variables, el canal SMS simula envíos.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=  # número Twilio o Messaging Service SID

# Cola BullMQ — Redis (Upstash recomendado). Sin esta URL, los Reminders
# quedan en estado PENDING y no se procesan (no se rompe nada).
# REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6379

# Lanzar el worker dentro del mismo proceso del backend (true en dev).
# En producción es mejor un servicio Render aparte: `node src/notifications/worker.js`
# NOTIFICATIONS_WORKER_INPROCESS=false

# ===========================================
# IA (Anthropic + embeddings)
# ===========================================
# Claude para el agente IA público, bot de WhatsApp y asistente de plantillas.
# Sin esta key, esos endpoints devuelven 503 o caen a respuestas hardcoded.
# ANTHROPIC_API_KEY=sk-ant-xxx
# OpenAI para embeddings (RAG del agente IA). Sin key, RAG no aporta contexto.
# OPENAI_API_KEY=sk-xxx

# ===========================================
# Cloudinary (subida de imágenes)
# ===========================================
# Perfiles del directorio, documentos del agente IA, blog.
# CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud_name>

# ===========================================
# Cron interno + notificaciones
# ===========================================
# Corre los jobs (nurture, cumpleaños, controles, blog IA) desde el mismo proceso.
# En prod con Redis+worker separado, desactivar (false).
# INTERNAL_CRON_ENABLED=true
# CRON_SECRET=un_secreto_para_endpoint_manual_de_crons
# INTERNAL_NOTIFY_EMAIL=alertas@oirconecta.com

# ===========================================
# Directorio profesional (multi-tenant)
# ===========================================
# Perfiles del directorio propios de OírConecta (además del retail).
# Coma-separado. Se exponen en /api/public/retail-config.
# OWN_DIRECTORY_PROFILE_IDS=
# Secreto JWT independiente para sesiones del portal profesional.
# Si está vacío, se deriva de JWT_SECRET.
# DIRECTORY_JWT_SECRET=
# DIRECTORY_JWT_EXPIRES_IN=30d

# ===========================================
# Pagos
# ===========================================
# Proveedor de pagos. Sin valor, se usa el stub (pedidos quedan PENDING
# hasta aprobación manual).
# PAYMENT_PROVIDER=wompi   # opciones futuras: wompi | mercadopago

# ===========================================
# URLs públicas y contacto
# ===========================================
# PUBLIC_SITE_URL=https://oirconecta.com
# SITE_URL=https://oirconecta.com          # alias legacy usado por algunos servicios
# PUBLIC_API_URL=https://oirconecta-api.onrender.com
# CENTRO_TELEFONO=+573171503944
# CENTRO_WHATSAPP=+573171503944

# ===========================================
# Sales / captación
# ===========================================
# SALES_FROM_EMAIL=comercial@oirconecta.com
# SALES_FROM_NAME="Equipo OírConecta"

# ===========================================
# Blog IA (cron semanal)
# ===========================================
# BLOG_AUTO_ENABLED=true
# BLOG_AUTO_PUBLISH=false               # true = publica al vuelo; false = deja en DRAFT
# BLOG_CLAUDE_MODEL=claude-haiku-4-5-20251001

# ===========================================
# Correo (Sender.net alternativa a Resend)
# ===========================================
# SENDER_API_KEY=
