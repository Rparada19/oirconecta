{
  "name": "oirconecta-backend",
  "version": "1.0.0",
  "description": "Backend API para OirConecta CRM",
  "main": "src/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate",
    "dev": "nodemon src/index.js",
    "start": "prisma db push --accept-data-loss && (node scripts/seed_blog_articles.js || echo 'seed blog falló, continuando') && (node scripts/seed_blog_covers.js || echo 'seed covers falló, continuando') && node src/index.js",
    "blog:seed": "node scripts/seed_blog_articles.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset --accept-data-loss && node prisma/seed.js",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "notifications:worker": "node src/notifications/worker.js",
    "notifications:seed": "node prisma/seeds/notification-templates.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.1",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "gray-matter": "^4.0.3",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.19.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "prisma": "^5.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
