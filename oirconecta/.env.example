# Copia a .env.production.local o configura en tu hosting (Vite solo expone variables que empiezan por VITE_)

# URL base del API en producción (sin barra final). Ejemplo: https://api.tudominio.com
VITE_API_URL=https://api.tudominio.com

# Opcional: WhatsApp para CTAs del sitio público (solo dígitos, ej. país + número)
# VITE_WHATSAPP_NUMBER=573001234567
# O URL completa:
# VITE_WHATSAPP_URL=https://wa.me/573001234567

# Video educativo en la home (embed, ej. YouTube):
# VITE_HOME_VIDEO_EMBED_URL=https://www.youtube.com/embed/XXXXXXXXXXX
