# Opcional: copia a `.env` o `.env.local` en la RAÍZ del monorepo.
# Solo lo usa `npm run dev` (scripts/dev.mjs) para coordinar API + Vite sin choques de puertos.

# Puerto preferido del backend. Si está ocupado, `npm run dev` en la raíz y el propio API en desarrollo prueban el siguiente libre.
BACKEND_PORT=3001

# Puerto preferido de Vite (sitio + CRM). Si está ocupado, `npm run dev` prueba el siguiente libre.
FRONTEND_PORT=5174

# Opcional: puertos extra permitidos por CORS del API en desarrollo (separados por coma).
# El script de dev siempre incluye FRONTEND_PORT en la lista.
# CORS_DEV_PORTS=5173,5174,5175,5180
